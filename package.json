{
  "name": "@your-scope/your-package",
  "version": "0.0.0",
  "description": "",
  "license": "ISC",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --config .config/vite.config.ts",
    "typecheck": "tsc --noEmit -p .config/tsconfig.json",
    "test": "vitest run --config .config/vitest.config.ts",
    "test:watch": "vitest --config .config/vitest.config.ts",
    "lint": "pnpm lint:check --fix",
    "lint:check": "pnpm exec oxlint -c .config/.oxlintrc.json",
    "fmt": "pnpm exec oxfmt -c .config/.oxfmtrc.json",
    "fmt:check": "pnpm fmt --check",
    "pub:version": "pnpm exec changeset version",
    "pub:release": "pnpm build && pnpm exec changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-dts": "5.0.2",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "pnpm@11.8.0"
}
